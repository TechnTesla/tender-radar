# Copy to .env and fill with real values. .env is gitignored.
# ---------------------------------------------------------------------------

# Project URL — Supabase dashboard > Settings > Data API (looks like https://<ref>.supabase.co)
SUPABASE_URL=

# Publishable key (client-safe) — used by web/. Dashboard > Settings > API Keys.
# New projects: sb_publishable_...   Legacy: the "anon" key.
SUPABASE_PUBLISHABLE_KEY=

# Secret key (SERVER ONLY — bypasses row-level security) — used by pipeline/.
# Dashboard > Settings > API Keys.  New projects: sb_secret_...  Legacy: "service_role".
# Never expose this in the browser or any NEXT_PUBLIC_/VITE_ variable.
SUPABASE_SECRET_KEY=

# Direct Postgres connection string — used by pipeline/ for bulk inserts.
# Dashboard > click "Connect" (top of page) > choose Session/Transaction pooler.
# Replace [YOUR-PASSWORD] with your database password.
DATABASE_URL=
